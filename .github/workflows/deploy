name: Deploy to PyPI

on:
  push:
    branches:
      - 'deploy' # Change this to whatever branch you want to trigger the deployment

jobs:
  pypi-publish:
    name: Build and publish to PyPI
    runs-on: ubuntu-latest
    
    # These permissions are required if you are using PyPI's Trusted Publishing (OIDC)
    permissions:
      id-token: write  
      contents: read

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.x" # Replace with your target Python version

      - name: Install build tools
        run: python -m pip install --upgrade pip build

      - name: Build source and wheel distribution
        run: python -m build

      - name: Publish package to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1
        # NOTE: If you are using a traditional API token instead of Trusted Publishing, 
        # uncomment the two lines below and ensure your secret is configured in GitHub.
        # with:
        #   password: ${{ secrets.PYPI_API_TOKEN }}
